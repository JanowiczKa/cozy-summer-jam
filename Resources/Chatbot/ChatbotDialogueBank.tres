[ext_resource type="Script" uid="uid://ejqd4lbb2hy4" path="res://Scripts/Chatbot/ChatBotDialogueBank.cs" id="1_wy7fp"]

[resource]
script = ExtResource("1_wy7fp")
IntroDialogue = PackedStringArray("Ah yes, {drink} - here\'s a recipe, as you requested.")
OutroDialogue = PackedStringArray("Great job, the customer gave you a score of {score}%! A happy customer is not just an achievement - it\'s a stepping stone towards your next positive work evaluation meeting.", "It seems the customer gave you a score of {score}%, but don\'t worry - there\'s always the next time! Make sure you follow my recipies to the letter and you\'ll be meeting our customers\' (and shareholders\') expectations in no time.", "Unfortunately, the customer gave your drink a score of {score}%. Please be careful not to deviate from the provided recipe - the shareholders are watching!", "Please stop loitering, company time is our most valuable asset.")
FinalScore = "It looks like there are no more customers to serve today - let's see how you performed."
FinalScoreResult = PackedStringArray("Good work - your performance was exceptional! Unfortunately, this marks the end of your unpaid probation period. Management has decided that the bar doesn\'t need another employee - we wish you good luck searching for a position elsewhere.", "Don\'t worry - everybody makes mistakes! You can always try again next time. Unfortunately, there will be no \'next time\' - this marks the end of your unpaid probation period. Management has decided that the bar doesn\'t need another employee - we wish you good luck searching for a position elsewhere.", "Your performance today did not meet our shareholder\'s expectations. Unfortunately, this marks the end of your unpaid probation period and your employment here. We wish you good luck searching for a position elsewhere.")
