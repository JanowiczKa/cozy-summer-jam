script = ExtResource("4_psg0o")
Dialog = PackedStringArray("I still remember the day o’ the Incident. The screams. The Sludge. The ‘orrors o’ tentacles descendin’ from the skies. It be Cthulhu,’ I ‘ad ‘ollered.", "Nothin’ like Sea Water to stop ye growin’ grim about the mouth, matey.", "My daughter loved usin’ Fish Eyes as marbles when she were young. Now she just be on… TikiTok?")
