[sub_resource type="Resource" id="Resource_mgfao"]
script = ExtResource("4_w61qc")
Dialog = PackedStringArray("I haven’t been to the Abyssal Zone- I hear they make a gorgeous rum. Not that you would know.", "My company, Crabshell Cola, just launched a marketing campaign on some social media site- Teepee Tok or some such?", "That had better not be imitation Squid Ink. Don’t try to lie, either- I have quite a discerning palate.", "You have Caviar? In a place like this? Well, miracles really do happen.")
Expression = PackedStringArray("Neutral", "Neutral", "Angry", "Neutral")
metadata/_custom_type_script = "uid://biw2gp20tmj0e"

