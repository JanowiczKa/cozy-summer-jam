[sub_resource type="Resource" id="Resource_2b3aw"]
script = ExtResource("3_x6u2d")
Dialog = PackedStringArray("My soul has felt blacker than Squid Ink since Sheila left me…", "My friend, Captain Morgan, has always recommended Abyssal Zone Rum.", "I used to work in a Crabshell Cola factory… before the… Incident. No, not that one. I mean Sheila up and leaving me.", "Caviar… fancy stuff. More my wife’s speed.")
Expression = PackedStringArray("Angry", "Neutral", "Neutral", "Neutral")
metadata/_custom_type_script = "uid://biw2gp20tmj0e"

